<script>
    // 세션에서 데이터 로드
    const diagnosisData = sessionStorage.getItem('diagnosisData');
    let analysis = null;

    if (diagnosisData) {
        const data = JSON.parse(diagnosisData);
        document.getElementById('brandName').textContent = data.brandName || '브랜드명';
        
        // 분석 데이터가 있으면 파싱
        try {
            if (typeof data.analysis === 'string') {
                analysis = JSON.parse(data.analysis);
            } else if (typeof data.analysis === 'object') {
                analysis = data.analysis;
            }
        } catch (e) {
            console.warn('분석 데이터 파싱 실패:', e);
        }
    }

    // 데이터 표시
    if (analysis) {
        renderReport();
    } else {
        // API에서 받은 분석이 없으면 기본값 표시
        renderDefaultReport();
    }

    function renderReport() {
        // 헤더
        document.getElementById('totalScore').textContent = analysis.total_score || 0;
        document.getElementById('brandSummary').textContent = analysis.summary_verdict || 'AI 브랜드 진단 리포트';

        // 상태 배지
        const badges = document.getElementById('statusBadges');
        badges.innerHTML = '';
        if (analysis.total_score < 40) {
            badges.innerHTML += '<div class="badge critical">위기</div>';
        } else if (analysis.total_score < 60) {
            badges.innerHTML += '<div class="badge warning">주의</div>';
        }
        badges.innerHTML += '<div class="badge info">' + (analysis.summary_verdict?.split('·')[0] || '진단 완료') + '</div>';

        // 진단
        document.getElementById('criticalDiagnosis').innerHTML = `<p>${analysis.critical_diagnosis}</p>`;

        // 지표
        document.getElementById('score1').textContent = analysis.metrics.message_clarity;
        document.getElementById('reason1').textContent = analysis.metrics.message_clarity_reason;
        document.getElementById('score2').textContent = analysis.metrics.differentiation;
        document.getElementById('reason2').textContent = analysis.metrics.differentiation_reason;
        document.getElementById('score3').textContent = analysis.metrics.conversion_path;
        document.getElementById('reason3').textContent = analysis.metrics.conversion_path_reason;

        // 레이더 차트
        renderRadarChart();

        // 병목
        const gapsContainer = document.getElementById('gapsContainer');
        gapsContainer.innerHTML = '';
        if (analysis.strategic_gaps && analysis.strategic_gaps.length > 0) {
            analysis.strategic_gaps.forEach((gap, idx) => {
                gapsContainer.innerHTML += `
                    <div class="gap-card">
                        <div class="gap-problem">█ ${idx + 1}. ${gap.problem}</div>
                        <div class="gap-impact"><strong>영향:</strong> ${gap.impact}</div>
                    </div>
                `;
            });
        }

        // 페르소나 (기본 분석에서 추출)
        const targetAnalysis = extractTargetAnalysis(analysis.critical_diagnosis);
        document.getElementById('painPoint').textContent = targetAnalysis.pain || '타깃이 느끼는 핵심 불안감';
        document.getElementById('realNeed').textContent = targetAnalysis.need || '타깃이 진짜 원하는 것';
        document.getElementById('positioningStrategy').textContent = targetAnalysis.strategy || '당신의 새로운 포지셔닝 방향';

        // 상담 미리보기
        document.getElementById('consultingPreview').innerHTML = `<p>${analysis.consulting_preview}</p>`;
    }

    function renderRadarChart() {
        const ctx = document.getElementById('radarChart').getContext('2d');
        const labels = ['메시지 선명도', '차별화 지수', '전환 설계도', '신뢰도 (추정)', '타깃 적합도'];
        const scores = [
            analysis.metrics.message_clarity,
            analysis.metrics.differentiation,
            analysis.metrics.conversion_path,
            Math.round((analysis.metrics.message_clarity + analysis.metrics.differentiation) / 2),
            Math.round((analysis.metrics.conversion_path + analysis.total_score) / 2)
        ];

        new Chart(ctx, {
            type: 'radar',
            data: {
                labels: labels,
                datasets: [{
                    label: '귀사의 브랜드 점수',
                    data: scores,
                    borderColor: '#4B4545',
                    backgroundColor: 'rgba(75, 69, 69, 0.1)',
                    borderWidth: 2,
                    pointRadius: 4,
                    pointBackgroundColor: '#4B4545',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                scales: {
                    r: {
                        beginAtZero: true,
                        max: 100,
                        ticks: {
                            stepSize: 20,
                            color: '#888',
                            font: { size: 11 }
                        },
                        grid: { color: '#e0e0e0' }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });
    }

    function extractTargetAnalysis(text) {
        // 간단한 분석으로 기본값 반환
        return {
            pain: '타깃이 느끼는 핵심 불안감이 명시되지 않음',
            need: '당신의 서비스가 해결해줄 실제 니즈 정의 필요',
            strategy: '타깃의 심리 상태를 반영한 새로운 포지셔닝'
        };
    }

    function renderDefaultReport() {
        document.getElementById('totalScore').textContent = '진단 중...';
    }

    function openCalendar() {
        window.location.href = 'https://cal.com/chaeum';
    }
</script>
